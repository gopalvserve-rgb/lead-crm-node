{
  "appId": "app.leadcrm.mobile",
  "appName": "Lead CRM",
  "webDir": "www",
  "server": {
    "url": "https://crm.celesteabode.com",
    "cleartext": false,
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "crm.celesteabode.com",
      "tel:*",
      "mailto:*",
      "whatsapp:*"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0F172A",
    "webContentsDebuggingEnabled": false
  },
  "ios": {
    "backgroundColor": "#0F172A",
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false,
    "scrollEnabled": true,
    "preferredContentMode": "mobile",
    "scheme": "App"
  }
}
