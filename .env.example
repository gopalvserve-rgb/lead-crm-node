# ============================================================
# Lead CRM — Node.js config
# Copy this file to .env and fill in real values.
# ============================================================

# Express server port
PORT=3000

# --- PostgreSQL ---------------------------------------------
# Use a managed Postgres (Supabase/Neon/Railway/Render) and paste the connection string here.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# For Supabase/Neon/Render use the "pooled" connection string.
DATABASE_URL=postgres://postgres:password@localhost:5432/leadcrm

# Set to 1 for managed providers that require SSL (Supabase, Neon, Render, Railway).
# Leave 0 for local Postgres.
DB_SSL=1

# ------------------------------------------------------------

# JWT secret for auth tokens (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Seed admin account created by `npm run seed` (only if no users exist yet)
SEED_ADMIN_EMAIL=admin@crm.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin

# App metadata (same keys as Apps Script Script Properties)
COMPANY_NAME=Lead CRM
COMPANY_LOGO_URL=

# Meta / Facebook / Instagram Lead Ads
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=change-to-any-long-random-string

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=change-to-any-long-random-string

# Website form API key (used by /hook/website)
WEBSITE_API_KEY=change-to-any-long-random-string

# Duplicate lead policy: allow | assign_same_user | skip_assignment | reject
DUPLICATE_POLICY=allow
DUPLICATE_WINDOW_HOURS=24
DUPLICATE_MATCH_FIELDS=phone,email

# Default lead list columns
DEFAULT_LEAD_COLUMNS=name,phone,source,product,status,assigned,followup,created

# HR settings
ENFORCE_GPS=0
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_M=300
WORK_START=09:30
WORK_END=18:30
WEEKLY_OFFS=0,6

# Leads list header visibility
SHOW_LEADS_HEADER=1

# Email notifications via SMTP (nodemailer)
EMAIL_NOTIFY_ENABLED=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_NOTIFY_FROM=Lead CRM <noreply@yourcompany.com>
EMAIL_NOTIFY_SUBJECT_PREFIX=[Lead CRM]
FOLLOWUP_REMIND_MIN=15
